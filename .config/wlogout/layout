{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "(L)",
    "keybind" : "l",
}
{
    "label" : "reboot",
    "action" : "loginctl reboot",
    "text" : "(R)",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "loginctl poweroff",
    "text" : "(S)",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch 'hl.dsp.exit()'",
    "text" : "(E)",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "loginctl suspend",
    "text" : "(Z)",
    "keybind" : "z"
}
{
    "label" : "hibernate",
    "action" : "loginctl hibernate",
    "text" : "(H)",
    "keybind" : "h"
}
